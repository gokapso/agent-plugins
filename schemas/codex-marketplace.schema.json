{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kapso.ai/schemas/agent-plugins/codex-marketplace.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "interface", "plugins"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "interface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["displayName"],
      "properties": {
        "displayName": { "type": "string", "minLength": 1 }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "source", "policy", "category"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "source": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "path"],
            "properties": {
              "source": { "const": "local" },
              "path": { "$ref": "shared-defs.schema.json#/$defs/relativePath" }
            }
          },
          "policy": {
            "type": "object",
            "additionalProperties": false,
            "required": ["installation", "authentication"],
            "properties": {
              "installation": { "enum": ["AVAILABLE"] },
              "authentication": { "enum": ["ON_INSTALL", "NONE"] }
            }
          },
          "category": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
